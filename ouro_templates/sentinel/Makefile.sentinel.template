# --- Ouro Sentinel targets ---
# Add these to your project Makefile

sentinel-start:
	@nohup {{SENTINEL_DIR}}/sentinel-runner.sh start >> {{SENTINEL_DIR}}/runner.log 2>&1 & disown

sentinel-stop:
	@{{SENTINEL_DIR}}/sentinel-runner.sh stop

sentinel-restart:
	@{{SENTINEL_DIR}}/sentinel-runner.sh restart

sentinel-dashboard:
	@{{SENTINEL_DIR}}/sentinel-dashboard.sh

sentinel-watch:
	@{{SENTINEL_DIR}}/sentinel-dashboard.sh --watch

sentinel-status:
	@ouro-sentinel status .

sentinel-partition:
	@ouro-sentinel partition .
